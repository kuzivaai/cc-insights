{
  "name": "cc-insights",
  "displayName": "CC Insights",
  "description": "Linter for CLAUDE.md files. Finds stale file references, missing build commands, and bloat. No telemetry.",
  "version": "0.3.0",
  "author": "kuzivaai",
  "publisher": "kuzivaai",
  "repository": {
    "type": "git",
    "url": "https://github.com/kuzivaai/cc-insights.git",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/kuzivaai/cc-insights",
  "bugs": "https://github.com/kuzivaai/cc-insights/issues",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "workspaceContains:**/CLAUDE.md",
    "workspaceContains:**/.claude"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cc-insights.analyse",
        "title": "CC Insights: Analyse CLAUDE.md"
      },
      {
        "command": "cc-insights.fixAll",
        "title": "CC Insights: Fix All"
      }
    ],
    "configuration": {
      "title": "CC Insights",
      "properties": {
        "ccInsights.fixOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Auto-fix CLAUDE.md issues on save"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --conditions=require",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@ccinsights/core": "workspace:*",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0"
  }
}
