{
  "name": "cc-insights",
  "displayName": "CC Insights — CLAUDE.md Linter",
  "description": "Actionable diagnostics for CLAUDE.md files. Detects stale references, bloat, missing commands. No telemetry.",
  "version": "0.1.0",
  "publisher": "cc-insights",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "workspaceContains:**/CLAUDE.md",
    "workspaceContains:**/.claude"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cc-insights.analyse",
        "title": "CC Insights: Analyse CLAUDE.md"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --conditions=require",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cc-insights/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0"
  }
}
