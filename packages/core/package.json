{
  "name": "@cc-insights/core",
  "version": "0.1.0",
  "description": "Actionable intelligence for Claude Code — CLAUDE.md health analysis, insight rules, and session diagnostics",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./parser": {
      "import": "./dist/parser/index.js",
      "require": "./dist/parser/index.cjs",
      "types": "./dist/parser/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claudemd",
    "insights",
    "analytics",
    "linter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
